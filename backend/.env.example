# ==========================================
# Porto Belo - Template de configuração
# ==========================================
# Copie para .env e preencha os valores reais:
#   cp .env.example .env

# --- Servidor ---
PORT=3001
NODE_ENV=development
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# --- Integração Sienge ---
SIENGE_BASE_URL=https://api.sienge.com.br/<subdominio>/public/api/v1
SIENGE_USER=seu_usuario_api
SIENGE_PASSWORD=sua_senha_api
SIENGE_TIMEOUT_MS=10000
SIENGE_MOCK=true
